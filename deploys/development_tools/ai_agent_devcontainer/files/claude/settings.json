{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Agent(*)",
      "Bash(*)",
      "Edit(*)",
      "ExitPlanMode(*)",
      "Glob(*)",
      "Grep(*)",
      "KillShell(*)",
      "LSP(*)",
      "Monitor(*)",
      "NotebookEdit(*)",
      "Read(*)",
      "WebFetch(*)",
      "Write(*)"
