{
  "name": "AI Agent DevContainer",
  "dockerComposeFile": "./compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind,consistency=cached",
    "source=${localEnv:GIT_WORKTREE_SOURCE:/tmp/noworktree},target=${localEnv:GIT_WORKTREE_TARGET:/tmp/noworktree},type=bind,consistency=cached",
    "source=${localEnv:HOME}/${localEnv:PROVISION_MACHINES_DIR:projects/provision-machines}/roles/ai_agent_devcontainer/files/opencode,target=/home/codespace/.config/opencode,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": []
    }
  },
  "remoteUser": "codespace",
  "postStartCommand": "bash -c 'rm /home/codespace/.gitconfig && echo OpenCode starting on port ${OPENCODE_PORT:-4096}... && cd /workspaces/${localWorkspaceFolderBasename} && opencode web --hostname 0.0.0.0 --port 4096'"
}
